# GitHub username used for dynamic repo fetching (client-side, public API)
NEXT_PUBLIC_GITHUB_USERNAME=proffaro

# Optional: a GitHub personal access token (read-only, public_repo scope)
# raises the unauthenticated rate limit from 60 -> 5000 req/hr.
# Only used server-side. Leave blank to use unauthenticated requests.
GITHUB_TOKEN=
